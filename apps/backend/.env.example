# ApplyFlow backend environment example
# Copy to .env for local use. Never commit real .env files.

# Required: runtime profile
SPRING_PROFILES_ACTIVE=dev

# Required: database
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Required: Redis for distributed rate limiting outside isolated local tests
REDIS_HOST=
REDIS_PORT=6379
REDIS_TIMEOUT=2s
REDIS_CONNECT_TIMEOUT=2s

# Required: JWT
JWT_ISSUER=applyflow
JWT_AUDIENCE=applyflow-web
JWT_SECRET_BASE64=

# Required: browser/API boundary
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Required in staging/prod: actuator metrics protection
ACTUATOR_METRICS_TOKEN=

# Security headers
SECURITY_HEADERS_MODE=dev
SECURITY_HSTS_ENABLED=false
SECURITY_CSP_DEV=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:3000 http://localhost:8080; frame-ancestors 'none';
SECURITY_CSP_PROD=default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none';

# Rate limiting
RATE_LIMIT_REDIS_ENABLED=true
RATE_LIMIT_FALLBACK_ENABLED=true
RATE_LIMIT_SIMULATION_ENABLED=false
RATE_LIMIT_SIMULATION_MODE=none
RATE_LIMIT_SIMULATED_LATENCY_MS=0
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REDIS_KEY_PREFIX=applyflow:ratelimit:
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_REFRESH_LIMIT=10
RATE_LIMIT_RESUME_UPLOAD_LIMIT=6
RATE_LIMIT_RESUME_VARIANT_LIMIT=10
RATE_LIMIT_APPLICATION_DRAFT_LIMIT=12
RATE_LIMIT_VACANCY_READ_LIMIT=90
RATE_LIMIT_MATCH_ANALYSIS_LIMIT=60
RATE_LIMIT_AI_ENRICHMENT_LIMIT=20

# Vacancy ingestion
INGESTION_ENABLED=false
INGESTION_BOOTSTRAP_ENABLED=false
INGESTION_BOOTSTRAP_SOURCE=REMOTIVE
INGESTION_BOOTSTRAP_MAX_JOBS_PER_RUN=120
INGESTION_BOOTSTRAP_ONLY_WHEN_VACANCIES_EMPTY=true
INGESTION_BOOTSTRAP_REQUIRE_NO_RUNS=true
INGESTION_BOOTSTRAP_ALLOWED_PROFILES=staging,dev
INGESTION_SCHEDULER_ENABLED=false
INGESTION_REMOTIVE_DELAY_MS=1800000
INGESTION_GREENHOUSE_DELAY_MS=3600000
INGESTION_LEVER_DELAY_MS=3600000
INGESTION_ADZUNA_DELAY_MS=3600000
INGESTION_JOB_SEARCH_PREFERENCES_DELAY_MS=3600000

# Remotive provider
INGESTION_REMOTIVE_ENABLED=true
INGESTION_REMOTIVE_BASE_URL=https://remotive.com
INGESTION_REMOTIVE_JOBS_PATH=/api/remote-jobs
INGESTION_REMOTIVE_CONNECT_TIMEOUT_MS=2000
INGESTION_REMOTIVE_READ_TIMEOUT_MS=5000
INGESTION_REMOTIVE_MAX_PAYLOAD_BYTES=1500000
INGESTION_REMOTIVE_MAX_JOBS_PER_RUN=300
INGESTION_REMOTIVE_ALLOWED_HOSTS=remotive.com

# Greenhouse provider
INGESTION_GREENHOUSE_ENABLED=false
INGESTION_GREENHOUSE_BASE_URL=https://boards-api.greenhouse.io
INGESTION_GREENHOUSE_CONNECT_TIMEOUT_MS=2000
INGESTION_GREENHOUSE_READ_TIMEOUT_MS=5000
INGESTION_GREENHOUSE_MAX_PAYLOAD_BYTES=5000000
INGESTION_GREENHOUSE_MAX_JOBS_PER_RUN=200
INGESTION_GREENHOUSE_ALLOWED_HOSTS=boards-api.greenhouse.io

# Lever provider
INGESTION_LEVER_ENABLED=false
INGESTION_LEVER_BASE_URL=https://api.lever.co
INGESTION_LEVER_CONNECT_TIMEOUT_MS=2000
INGESTION_LEVER_READ_TIMEOUT_MS=5000
INGESTION_LEVER_MAX_PAYLOAD_BYTES=1500000
INGESTION_LEVER_MAX_JOBS_PER_RUN=200
INGESTION_LEVER_ALLOWED_HOSTS=api.lever.co

# Adzuna provider (optional; required only when ADZUNA is enabled)
INGESTION_ADZUNA_ENABLED=false
INGESTION_ADZUNA_BASE_URL=https://api.adzuna.com
INGESTION_ADZUNA_CONNECT_TIMEOUT_MS=2000
INGESTION_ADZUNA_READ_TIMEOUT_MS=5000
INGESTION_ADZUNA_MAX_PAYLOAD_BYTES=1500000
INGESTION_ADZUNA_MAX_JOBS_PER_RUN=200
INGESTION_ADZUNA_ALLOWED_HOSTS=api.adzuna.com
INGESTION_ADZUNA_APP_ID=
INGESTION_ADZUNA_APP_KEY=

# AI provider (optional; AI never owns deterministic scoring)
AI_ENABLED=false
AI_PROVIDER_NAME=openai-compatible
AI_PROVIDER_BASE_URL=https://api.openai.com
AI_PROVIDER_CHAT_PATH=/v1/chat/completions
AI_PROVIDER_MODEL=
AI_PROVIDER_API_KEY=
AI_PROVIDER_CONNECT_TIMEOUT_MS=2000
AI_PROVIDER_READ_TIMEOUT_MS=8000
AI_PROVIDER_MAX_RETRIES=1
AI_PROVIDER_MAX_COMPLETION_TOKENS=400
AI_PROVIDER_TEMPERATURE=0.2
AI_PROVIDER_ALLOWED_HOSTS=api.openai.com

# Resume storage
RESUME_STORAGE_BASE_DIR=./data/private/resumes
RESUME_MAX_PDF_BYTES=5242880

# Runtime smoke credentials; use only synthetic data
SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

# Admin bootstrap; disabled by default
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FORCE_PASSWORD_RESET=false
BOOTSTRAP_ADMIN_ALLOWED_PROFILES=staging,dev
